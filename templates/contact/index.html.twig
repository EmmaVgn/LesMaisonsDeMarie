{% extends 'base.html.twig' %}

{% block title %}Nous contacter
{% endblock %}

{% block body %}
	<div class="home">
		<div class="contact">
			<div class="container text-center">
				<div class="container">
					<h1>Nous contacter</h1>
					{{ form_start(form) }}
					{{ form_errors(form) }}
					<div class="row">
						<div class="col-md-6 mb-3">
							{{ form_row(form.firstname, {'attr': {'class': 'form-control mb-3'}}) }}
							{{ form_row(form.lastname, {'attr': {'class': 'form-control mb-3'}}) }}
						</div>
						<div class="col-md-6 mb-3">
							{{ form_row(form.phone, {'attr': {'class': 'form-control mb-3'}}) }}
							{{ form_row(form.email, {'attr': {'class': 'form-control mb-3'}}) }}
						</div>
						<div class="col-md-6 mb-3">
							{{ form_row(form.content, {'attr': {'class': 'form-control'}}) }}
						</div>
					</div>
					<button class="btn btn-secondary mt-3 mb-10" type="submit">
						<span>Nous contacter</span>
					</button>
					{{ form_end(form) }}
				</div>
				<div class="container">
					<div class="col">
						<iframe src="https://storage.googleapis.com/maps-solutions-kzr224w2qv/neighborhood-discovery/8rpk/neighborhood-discovery.html" width="100%" height="520px" style="border:0;" loading="lazy"></iframe>
					</div>
				</div>

			</div>
		</div>
	</div>
</div>{% endblock %}
